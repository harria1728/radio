:&quot;2025-10-08T07:36:19.000000Z&quot;,&quot;updated_at&quot;:&quot;2025-10-08T07:36:19.000000Z&quot;}}],&quot;cabangwithprogram&quot;:[{&quot;cabang&quot;:{&quot;id_cabang&quot;:&quot;RAMAAXQZJW&quot;,&quot;nama_cabang&quot;:&quot;Rama Group&quot;,&quot;alamat&quot;:&quot;Indonesia&quot;,&quot;deskripsi&quot;:&quot;Rama Group merupakan salah satu jaringan stasiun radio yang memiliki pendengar setia, khususnya di wilayah Jawa Barat. Dikenal dengan format siaran yang merakyat dan menghibur, Rama Group berhasil menjangkau berbagai segmen pendengar di beberapa kota seperti Bandung, Cianjur, Sukabumi, dan masih banyak lagi.&quot;,&quot;logo&quot;:&quot;\/img\/cabang\/rama_1759777488_68e412d0d5b55.png&quot;,&quot;facebook&quot;:null,&quot;instagram&quot;:null,&quot;twitter&quot;:null,&quot;video&quot;:null,&quot;noice&quot;:null,&quot;youtube&quot;:null,&quot;tiktok&quot;:null,&quot;created_at&quot;:&quot;2025-10-06T19:04:48.000000Z&quot;,&quot;updated_at&quot;:&quot;2025-10-06T19:04:48.000000Z&quot;,&quot;link_api&quot;:null,&quot;program&quot;:[]},&quot;status&quot;:&quot;empty&quot;,&quot;program&quot;:null},{&quot;cabang&quot;:{&quot;id_cabang&quot;:&quot;RAMACGP4UO&quot;,&quot;nama_cabang&quot;:&quot;Rama Cianjur&quot;,&quot;alamat&quot;:&quot;Jl. KH Abdullah Bin Nuh No.99, Sawah Gede, Kec. Cianjur, Kabupaten Cianjur, Jawa Barat 43212&quot;,&quot;deskripsi&quot;:&quot;Radio Rama Cianjur 99.4 FM adalah bagian dari Rama Group, dan berlokasi di Cianjur, Jawa Barat. Radio ini menampilkan budaya lokal dan musik dari berbagai genre, diantaranya dangdut, musik daerah, hingga pop Indonesia.&quot;,&quot;logo&quot;:&quot;\/img\/cabang\/rama_1759075129_68d95b3955cff.png&quot;,&quot;facebook&quot;:null,&quot;instagram&quot;:null,&quot;twitter&quot;:null,&quot;video&quot;:null,&quot;noice&quot;:null,&quot;youtube&quot;:null,&quot;tiktok&quot;:null,&quot;created_at&quot;:&quot;2025-09-28T08:58:49.000000Z&quot;,&quot;updated_at&quot;:&quot;2025-10-06T17:15:14.000000Z&quot;,&quot